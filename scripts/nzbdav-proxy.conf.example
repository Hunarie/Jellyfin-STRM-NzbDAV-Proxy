# NZBDav Proxy rewrite config
# ---------------------------
# Copy this to a persistent path and edit it, then point the scripts at it via
# NZBDAV_PROXY_CONF (the scripts default to /boot/config/nzbdav-proxy.conf on
# Unraid, which survives reboots).
#
#   cp scripts/nzbdav-proxy.conf.example /boot/config/nzbdav-proxy.conf
#   nano /boot/config/nzbdav-proxy.conf
#
# This file is sourced by bash, so use KEY="value" with no spaces around '='.

# Your public Jellyfin base URL (no trailing slash).
JELLYFIN_URL="https://tv.jaydinleeman.com"

# The origin currently embedded in the .strm files — the string the rewrite
# script searches for. Two common scenarios:
#
#   Original setup (NZBDav writes its internal hostname into .strm files):
#     NZBDAV_ORIGIN="http://nzbdav:3000"
#
#   If you pointed NZBDav's base URL at the proxy so it writes proxy URLs
#   directly (no api_key), set this to the proxy prefix instead, so the
#   script detects those files and appends &api_key= to them:
#     NZBDAV_ORIGIN="https://tv.jaydinleeman.com/NZBDavProxy/Stream"
NZBDAV_ORIGIN="http://nzbdav:3000"

# A Jellyfin API key (Dashboard -> Advanced -> API Keys). Treat as a secret.
JELLYFIN_API_KEY="REPLACE_WITH_YOUR_JELLYFIN_API_KEY"

# The media root the watcher should monitor (host path on Unraid).
MEDIA_DIR="/mnt/user/media"
